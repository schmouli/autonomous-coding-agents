# ── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_USER=root
POSTGRES_PASSWORD=password
POSTGRES_DB=n8n

# ── n8n ───────────────────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=super-secret-key
N8N_USER_MANAGEMENT_JWT_SECRET=even-more-secret
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# ── OpenHands workspace ───────────────────────────────────────────────────
PROJECT_PATH=/path/to/your/project

# For Mac users running OLLAMA locally
# See https://github.com/n8n-io/autonomous-coding-agents?tab=readme-ov-file#for-mac--apple-silicon-users
OLLAMA_HOST=host.docker.internal:11434
DOCKER_EXTRA_HOSTS=host.docker.internal:host-gateway

# ── LLM (default: local qwen2.5-coder:7b via native Ollama) ──────────────
LLM_MODEL=openai/qwen2.5-coder:7b
LLM_API_KEY=ollama
LLM_BASE_URL=http://host.docker.internal:11434/v1

# ── Ollama cloud API key (used by switch-model.sh for cloud mode) ─────────
OLLAMA_API_KEY=your-ollama-api-key-here


